generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  password           String
  role               Role                @default(CASHIER)
  name               String?
  isActive           Boolean             @default(true)
  lastLogin          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  reviewedFeedback   CustomerFeedback[]
  orderModifications OrderModification[]
}

model Table {
  id          Int      @id @default(autoincrement())
  number      Int      @unique
  name        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model MenuCategory {
  id          Int        @id @default(autoincrement())
  titleEn     String
  titleKu     String
  titleAr     String
  image       String?
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  menuItems   MenuItem[]
}

model MenuItem {
  id            Int                @id @default(autoincrement())
  nameEn        String
  nameKu        String
  nameAr        String
  descriptionEn String?
  descriptionKu String?
  descriptionAr String?
  price         Float
  image         String?
  categoryId    Int
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  feedback      CustomerFeedback[]
  category      MenuCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
}

model Order {
  id              Int                 @id @default(autoincrement())
  tableId         Int?
  status          OrderStatus         @default(PENDING)
  subtotal        Float
  serviceCharge   Float               @default(0)
  total           Float
  priority        String              @default("NORMAL")
  isRush          Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  feedback        CustomerFeedback[]
  table           Table?              @relation(fields: [tableId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  modifications   OrderModification[]
  preparationTime PreparationTime[]
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  orderId    Int
  menuItemId Int
  quantity   Int
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ServiceChargeSettings {
  id              Int      @id @default(autoincrement())
  threshold       Float    @default(10.0)
  chargeAmount    Float    @default(0.0)
  isPercentage    Boolean  @default(true)
  percentageValue Float?   @default(0.0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DiscountSettings {
  id              Int       @id @default(autoincrement())
  threshold       Float     @default(0.0)
  discountAmount  Float     @default(0.0)
  isPercentage    Boolean   @default(true)
  percentageValue Float?    @default(0.0)
  isActive        Boolean   @default(true)
  isAllItems      Boolean   @default(true)
  menuItemIds     Json?     // Array of menu item IDs for individual item discounts
  specificDates   Json?     // Array of specific dates (e.g., ["2024-12-25", "2024-12-31"])
  startDate       DateTime? // Start date for date range
  endDate         DateTime? // End date for date range
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Analytics {
  id                Int      @id @default(autoincrement())
  date              DateTime @unique @default(now())
  totalOrders       Int      @default(0)
  totalRevenue      Float    @default(0)
  averageOrderValue Float    @default(0)
  peakHour          Int?
  ordersByStatus    Json?
  topItems          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model OrderModification {
  id               Int      @id @default(autoincrement())
  orderId          Int
  originalItemId   Int?
  originalQuantity Int?
  newQuantity      Int?
  modificationType String
  reason           String?
  modifiedBy       Int
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [modifiedBy], references: [id])
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model CustomerFeedback {
  id           Int       @id @default(autoincrement())
  orderId      Int?
  menuItemId   Int?
  rating       Int
  comment      String?
  feedbackType String
  status       String    @default("PENDING")
  reviewedBy   Int?
  reviewedAt   DateTime?
  response     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  menuItem     MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  order        Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewer     User?     @relation(fields: [reviewedBy], references: [id])
}

model PreparationTime {
  id        Int       @id @default(autoincrement())
  orderId   Int
  startTime DateTime?
  endTime   DateTime?
  duration  Int?
  status    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  CAPTAIN
  CASHIER
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}
